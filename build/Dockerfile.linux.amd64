FROM golang:1.26-alpine AS builder
RUN apk add --no-cache git
WORKDIR /src
COPY . .
RUN CGO_ENABLED=0 go build -o /mdm ./cmd/mdm-server

FROM alpine:3.22
COPY --from=builder /mdm /bin/mdm
COPY --from=builder /src/config.example.yaml /src/permissions.json /root/.mdm/
EXPOSE 8080 8443
ENTRYPOINT ["/bin/mdm"]
